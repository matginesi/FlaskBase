APP_ENV=development
FLASK_ENV=development

SECRET_KEY=change-me-with-a-long-random-secret

DATABASE_URL=postgresql+psycopg://webapp:webapp@127.0.0.1:5432/webapp
TEST_DATABASE_URL=postgresql+psycopg://webapp:webapp@127.0.0.1:5432/webapp_test

HOST=127.0.0.1
PORT=5000

# Host allow-list behavior
# - In development, by default we allow all hosts (useful for LAN testing).
#   Set DEV_ALLOW_ALL_HOSTS=false to enforce the ALLOWED_HOSTS list from DB.
DEV_ALLOW_ALL_HOSTS=true
# - In production, '*' is never allowed. If DB does not specify ALLOWED_HOSTS,
#   the app derives it from SETTINGS.BASE_URL. You can extend via:
EXTRA_ALLOWED_HOSTS=

# If you're behind a reverse proxy (nginx/traefik), enable ProxyFix *carefully*.
# Typical values: x_for=1, x_proto=1, x_host=1, x_port=1
PROXY_FIX_X_FOR=0
PROXY_FIX_X_PROTO=0
PROXY_FIX_X_HOST=0
PROXY_FIX_X_PORT=0
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
GUNICORN_RELOAD=false
WEB_WORKERS=2
JOB_WORKERS=1
WORKER_POLL_SEC=1.0

SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_SECURE=false
RATELIMIT_STORAGE_URI=redis://localhost:6379/0

CONFIG_PATH=app_config.json
SEED_PATH=seed/seed.json

SENDMAIL_PATH=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SEC=15
EMAIL_CONFIG_PATH=
